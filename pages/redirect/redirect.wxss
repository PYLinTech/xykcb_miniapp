page {
  min-height: 100vh;
  box-sizing: border-box;
  background: transparent;
}

.switching-page,
.redirect-page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.switching-page {
  background: transparent;
}

.redirect-page {
  background: #f7f7f7;
}

.switching-text {
  color: #191919;
  font-size: 42rpx;
  font-weight: 600;
}

.jump-button {
  width: 480rpx;
  max-width: 80%;
  height: 88rpx;
  margin: 0;
  padding: 0;
  border-radius: 18rpx;
  border: 0;
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 500;
  line-height: 88rpx;
  letter-spacing: 1rpx;
}

.jump-button::after {
  border: 0;
}

.jump-button:active {
  opacity: 0.88;
}

@media (prefers-color-scheme: dark) {
  .redirect-page {
    background: #1e1e1e;
  }

  .switching-text {
    color: #f2f2f2;
  }
}
