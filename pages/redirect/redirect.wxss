page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f7f7f7;
}

.jump-button {
  width: 480rpx;
  max-width: 80%;
  height: 88rpx;
  margin: 0;
  padding: 0;
  border-radius: 18rpx;
  border: 0;
  background: #00C29C;
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 500;
  line-height: 88rpx;
  letter-spacing: 1rpx;
  box-shadow: 0 12rpx 28rpx rgba(0, 194, 156, 0.22);
}

.jump-button::after {
  border: 0;
}

.jump-button:active {
  opacity: 0.88;
}

@media (prefers-color-scheme: dark) {
  page {
    background: #1e1e1e;
  }

  .jump-button {
    background: #00C29C;
    box-shadow: 0 12rpx 28rpx rgba(0, 194, 156, 0.24);
  }
}
